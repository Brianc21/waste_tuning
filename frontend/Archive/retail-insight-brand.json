  "typography": {
    "primary": {
      "family": "Monte Stella",
      "weights": [
        { "name": "Medium", "usage": "Headlines, display text" },
        { "name": "Regular", "usage": "Body, subheadings" }
      ]
    },
    "secondary": {
      "family": "Nexa",
      "weights": [
        { "name": "Bold", "usage": "Emphasis, CTAs" },
        { "name": "Text", "usage": "Body copy, UI text" }
      ]
    }
  },

  "toneOfVoice": {
    "personalities": [
      {
        "name": "Empathetic",
        "description": "Recognizes the specific pain points and priorities of retail and CPG leaders and addresses them in a tactful, authentic way.",
        "avoid": [
          "Underplaying challenges — making light of the pressures faced by retail and CPG leaders",
          "Overstating solutions — presenting products as a silver bullet to all retail problems"
        ]
      },
      {
        "name": "Human",
        "description": "Accessible, honest, and plain-speaking. Sometimes witty. Avoids inflated claims or unnecessary complexity.",
        "avoid": [
          "Verbose — using overly complex language and sentence structures which exclude audiences",
          "Robotic — using cookie-cutter B2B phrasing and marketing buzzwords"
        ]
      },
      {
        "name": "Progressive",
        "description": "Passionate, inspiring, and positive. Excited by innovation and the possibilities of technology.",
        "avoid": [
          "Traditional — outdated terminology for people, processes and technology",
          "Complacent — smugness or implying all answers are known"
        ]
      },
      {
        "name": "Rational",
        "description": "Evidence-based claims, well-reasoned arguments, and precise language. Avoids hyperbole and marketing-speak.",
        "avoid": [
          "Pretentious — elaborate explanations and superfluous language",
          "Arrogant — confidence based on subjective superiority rather than evidence"
        ]
      }
    ]
  },

  "styleGuide": {
    "language": "American English",
    "proofreadingTools": ["Grammarly"],
    "capitalization": {
      "rule": "Only capitalize product titles and specific job titles. General nouns are lowercase.",
      "productsCamelCase": [
        "WasteInsight",
        "AvailabilityInsight",
        "PromoInsight",
        "OnlineInsight",
        "StoreInsight",
        "RemodelInsight"
      ],
      "lowercaseNouns": [
        "retailers",
        "cognitive technology",
        "advanced analytics",
        "retail execution consultation",
        "dynamic pricing algorithm",
        "dynamic markdown software",
        "retail ecosystem",
        "consumer packaged goods"
      ]
    },
    "headlines": {
      "casing": "Sentence case — capitalize first word only, unless a capped noun appears"
    },
    "ctaButtons": {
      "casing": "Sentence case unless featuring a capped noun",
      "examples": ["Find out more", "Book your free consultation"]
    },
    "hyphens": {
      "compoundAdjectives": ["on-shelf", "in-store", "data-driven", "sell-through"]
    },
    "brandPositioning": "Shelf Actualization",
    "narrativeVoice": {
      "default": "First person — 'We' and 'our'",
      "formal": "Third person singular for press releases (e.g. 'Retail Insight is developing...' not 'Retail Insight are developing...')"
    },
    "partnerLanguage": "Refer to the brand's relationship with retailers and CPGs as 'partners'"
  },

  "products": [
    "WasteInsight",
    "AvailabilityInsight",
    "PromoInsight",
    "OnlineInsight",
    "StoreInsight",
    "RemodelInsight"
  ]
}
